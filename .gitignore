# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs / temp
*.log
*.tmp

# 임시·참고 파일 — git 추적 안 함
test.md
*.vsix
스크린샷*.png

# 런타임 캐시 — 로컬 경로·UUID 포함, git 추적 안 함
cache/

# superpowers 작업 진행 원장 — 스크래치, git 추적 안 함
.superpowers/

# Node / Vite 빌드 산출물
node_modules/
dist/
dist-ssr/
*.local

# Rust / Tauri 빌드 산출물
src-tauri/target/

# 작업 데이터 — 사용자 사적 자료, git 추적 안 함 (폴더 구조 유지를 위해 .gitkeep만 추적)
tasks/*
!tasks/.gitkeep

# 프로젝트 특화 교훈 — 작성자 사적 누적물, git 추적 안 함 (폴더만 유지)
_local/*
!_local/.gitkeep
